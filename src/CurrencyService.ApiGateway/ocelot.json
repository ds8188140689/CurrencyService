{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "host.docker.internal",
          "Port": 5159
        }
      ],
      "UpstreamPathTemplate": "/auth/{everything}",
      "UpstreamHttpMethod": [ "Get", "Post", "Put", "Delete" ],
      "SwaggerKey": "user-service"
    },
    {
      "DownstreamPathTemplate": "/api/currency/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "host.docker.internal",
          "Port": 5082
        }
      ],
      "UpstreamPathTemplate": "/finance/{everything}",
      "UpstreamHttpMethod": [ "Get", "Post", "Put", "Delete" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      },
      "SwaggerKey": "finance-service"
    }
  ],
  "SwaggerEndPoints": [
    {
      "Key": "user-service",
      "Config": [
        {
          "Name": "User API",
          "Version": "v1",
          "Url": "http://host.docker.internal:5159/swagger/v1/swagger.json"
        }
      ]
    },
    {
      "Key": "finance-service",
      "Config": [
        {
          "Name": "Finance API",
          "Version": "v1",
          "Url": "http://host.docker.internal:5082/swagger/v1/swagger.json"
        }
      ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5000",
    "RequestIdKey": "OcRequestId"
  }
}